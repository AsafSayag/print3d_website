# Copy to .env.local and fill in real values. See LEADS_SETUP.md for how to
# obtain each one. Never commit .env.local — it's already in .gitignore.

# Resend API key (email notification channel). Required for the email channel.
RESEND_API_KEY=re_xxxxxxxx

# Notification email recipient/sender. Both optional — see route.ts for defaults.
LEAD_NOTIFY_TO=asaf00500@gmail.com
LEAD_NOTIFY_FROM=Print3D <onboarding@resend.dev>

# Google Apps Script web-app URL (Sheet append channel). Required for the Sheet channel.
LEADS_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/AKfy.../exec
